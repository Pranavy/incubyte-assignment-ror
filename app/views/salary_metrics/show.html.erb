<% content_for :title, "Salary metrics — Incubyte Assignment" %>

<div class="container py-4">
  <h1 class="h3 mb-4">Salary metrics by job title</h1>

  <p class="text-muted mb-4">
    Average <strong>gross</strong> salary uses stored employee salaries.
    Average <strong>net</strong> uses TDS rules effective on the selected date, with defaults of 10% (India), 12% (United States), and 0% for other countries when no rule applies.
  </p>

  <div class="card shadow-sm border mb-4">
    <div class="card-body">
      <%= form_with url: salary_metrics_path, method: :get, local: true, class: "row g-3 align-items-end" do %>
        <div class="col-md-5">
          <%= label_tag :job_title_id, "Job title", class: "form-label" %>
          <%= select_tag :job_title_id,
                options_from_collection_for_select(@job_titles, :id, :title, @job_title_id),
                { include_blank: "Select a job title…", class: "form-select", required: true } %>
        </div>
        <div class="col-md-4">
          <%= label_tag :as_of, "As of (for TDS rules)", class: "form-label" %>
          <%= date_field_tag :as_of, @as_of, class: "form-control" %>
        </div>
        <div class="col-md-3">
          <%= submit_tag "Show metrics", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @job_title_id.present? && @metrics.nil? %>
    <div class="alert alert-warning" role="alert">
      No job title found for that selection.
    </div>
  <% elsif @metrics.present? %>
    <div class="card shadow-sm border">
      <div class="card-header bg-light">
        <strong><%= @metrics[:job_title] %></strong>
        <span class="text-muted small ms-2">(ID <%= @metrics[:job_title_id] %>)</span>
      </div>
      <div class="card-body">
        <% if @metrics[:avg_gross_salary].nil? %>
          <p class="text-muted mb-0">No employees have this job title. Averages are not available.</p>
        <% else %>
          <dl class="row mb-0">
            <dt class="col-sm-4 col-md-3">Average gross salary</dt>
            <dd class="col-sm-8 col-md-9"><%= number_to_currency(@metrics[:avg_gross_salary]) %></dd>
            <dt class="col-sm-4 col-md-3">Average net salary</dt>
            <dd class="col-sm-8 col-md-9"><%= number_to_currency(@metrics[:avg_net_salary]) %></dd>
            <dt class="col-sm-4 col-md-3">TDS reference date</dt>
            <dd class="col-sm-8 col-md-9"><%= l(@as_of) %></dd>
          </dl>
        <% end %>
      </div>
    </div>

    <p class="small text-muted mt-3 mb-0">
      JSON endpoint (same data):
      <code class="user-select-all"><%= api_salary_metrics_by_job_title_path(job_title_id: @metrics[:job_title_id], as_of: @as_of) %></code>
    </p>
  <% end %>
</div>
