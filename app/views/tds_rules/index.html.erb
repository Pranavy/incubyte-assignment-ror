<% content_for :title, "TDS rules — Incubyte Assignment" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">TDS rules</h1>
    <%= link_to "New TDS rule", new_tds_rule_path, class: "btn btn-primary" %>
  </div>

  <% if @tds_rules.any? %>
    <div class="table-responsive shadow-sm rounded border bg-white">
      <table class="table table-striped table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th scope="col">Country</th>
            <th scope="col">TDS rate</th>
            <th scope="col">Effective from</th>
            <th scope="col">Effective to</th>
            <th scope="col" class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @tds_rules.each do |rule| %>
            <tr>
              <td><%= Countries.label_for(rule.country) || rule.country %></td>
              <td><%= number_to_percentage(rule.tds_rate * 100, precision: 2) %></td>
              <td><%= l(rule.effective_from) %></td>
              <td><%= rule.effective_to.present? ? l(rule.effective_to) : "—" %></td>
              <td class="text-end">
                <%= link_to "View", tds_rule_path(rule), class: "btn btn-sm btn-outline-secondary" %>
                <%= link_to "Edit", edit_tds_rule_path(rule), class: "btn btn-sm btn-outline-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="d-flex justify-content-center mt-3">
      <%= will_paginate @tds_rules %>
    </div>
  <% else %>
    <p class="text-muted">No TDS rules yet. <%= link_to "Create one", new_tds_rule_path %>.</p>
  <% end %>
</div>
