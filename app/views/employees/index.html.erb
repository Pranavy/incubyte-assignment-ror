<% content_for :title, "Employees — Incubyte Assignment" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Employees</h1>
    <%= link_to "New employee", new_employee_path, class: "btn btn-primary" %>
  </div>

  <% if @employees.any? %>
    <div class="table-responsive shadow-sm rounded border bg-white">
      <table class="table table-striped table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Job title</th>
            <th scope="col">Country</th>
            <th scope="col" class="text-end">Salary</th>
            <th scope="col" class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @employees.each do |employee| %>
            <tr>
              <td><%= link_to "#{employee.first_name} #{employee.last_name}", employee_path(employee), class: "text-decoration-none" %></td>
              <td><%= employee.job_title.title %></td>
              <td><%= Countries.label_for(employee.country) || employee.country %></td>
              <td class="text-end"><%= number_to_currency(employee.salary) %></td>
              <td class="text-end">
                <%= link_to "View", employee_path(employee), class: "btn btn-sm btn-outline-secondary" %>
                <%= link_to "Edit", edit_employee_path(employee), class: "btn btn-sm btn-outline-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="d-flex justify-content-center mt-3">
      <%= will_paginate @employees %>
    </div>
  <% else %>
    <p class="text-muted">No employees yet. <%= link_to "Add one", new_employee_path %>.</p>
  <% end %>
</div>
