<% content_for :title, "#{@job_title.title} — Job title" %>

<div class="container py-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Job titles", job_titles_path %></li>
      <li class="breadcrumb-item active" aria-current="page"><%= @job_title.title %></li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-start mb-3">
    <h1 class="h3 mb-0"><%= @job_title.title %></h1>
    <%= link_to "Edit", edit_job_title_path(@job_title), class: "btn btn-primary" %>
  </div>

  <p class="text-muted small">Created <%= l(@job_title.created_at, format: :long) %></p>
</div>
