<% if @employee.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <h2 class="h6"><%= pluralize(@employee.errors.count, "error") %> prevented this employee from being saved:</h2>
    <ul class="mb-0 ps-3">
      <% @employee.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @employee, local: true, html: { class: "vstack gap-3" } do |f| %>
  <div>
    <%= f.label :first_name, class: "form-label" %>
    <%= f.text_field :first_name, class: "form-control", required: true, autocomplete: "given-name" %>
  </div>
  <div>
    <%= f.label :last_name, class: "form-label" %>
    <%= f.text_field :last_name, class: "form-control", required: true, autocomplete: "family-name" %>
  </div>
  <div>
    <%= f.label :country, class: "form-label" %>
    <%= f.select :country,
                 Countries.options_for_select,
                 { prompt: "Select country" },
                 class: "form-select",
                 required: true %>
  </div>
  <div>
    <%= f.label :job_title_id, "Job title", class: "form-label" %>
    <%= f.collection_select :job_title_id,
                            @job_titles,
                            :id,
                            :title,
                            { prompt: "Select job title" },
                            class: "form-select",
                            required: true %>
  </div>
  <% if @employee.new_record? %>
    <div>
      <%= f.label :salary, "Salary (gross)", class: "form-label" %>
      <%= f.number_field :salary, class: "form-control", step: "any", min: 0, required: true %>
    </div>
  <% end %>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", (@employee.persisted? ? employee_path(@employee) : employees_path), class: "btn btn-outline-secondary" %>
  </div>
<% end %>
