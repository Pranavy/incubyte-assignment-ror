<% content_for :title, "Job titles — Incubyte Assignment" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Job titles</h1>
    <%= link_to "New job title", new_job_title_path, class: "btn btn-primary" %>
  </div>

  <% if @job_titles.any? %>
    <div class="table-responsive shadow-sm rounded border bg-white">
      <table class="table table-striped table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th scope="col">Title</th>
            <th scope="col" class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @job_titles.each do |job_title| %>
            <tr>
              <td><%= link_to job_title.title, job_title_path(job_title), class: "text-decoration-none" %></td>
              <td class="text-end">
                <%= link_to "View", job_title_path(job_title), class: "btn btn-sm btn-outline-secondary" %>
                <%= link_to "Edit", edit_job_title_path(job_title), class: "btn btn-sm btn-outline-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">No job titles yet. <%= link_to "Create one", new_job_title_path %>.</p>
  <% end %>
</div>
