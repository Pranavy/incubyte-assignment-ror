<% content_for :title, "Incubyte" %>

<div class="container py-5">
  <div class="mx-auto" style="max-width: 40rem;">
    <h1 class="display-6 mb-2">Incubyte</h1>
    <p class="lead text-muted mb-4">
      Workforce, TDS rules, salary metrics, and dashboards for admins.
    </p>

    <% if admin_signed_in? %>
      <p class="small text-muted mb-3">Signed in as <strong><%= current_admin.email %></strong></p>
    <% end %>

    <div class="list-group shadow-sm">
      <% if admin_signed_in? %>
        <%= link_to "Dashboard", dashboard_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "Employees", employees_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "Job titles", job_titles_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "TDS rules", tds_rules_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "Salary metrics (by job title)", salary_metrics_job_title_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "Salary metrics (by country)", salary_metrics_country_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "Sign out", destroy_admin_session_path, data: { turbo_method: :delete }, class: "list-group-item list-group-item-action text-danger" %>
      <% else %>
        <%= link_to "Sign in", new_admin_session_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "Sign up", new_admin_registration_path, class: "list-group-item list-group-item-action" %>
      <% end %>
    </div>
  </div>
</div>
