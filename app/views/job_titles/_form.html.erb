<% if @job_title.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <h2 class="h6"><%= pluralize(@job_title.errors.count, "error") %> prevented this job title from being saved:</h2>
    <ul class="mb-0 ps-3">
      <% @job_title.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @job_title, local: true, html: { class: "vstack gap-3" } do |f| %>
  <div>
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true, autofocus: true, autocomplete: "organization-title" %>
  </div>
  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", (@job_title.persisted? ? job_title_path(@job_title) : job_titles_path), class: "btn btn-outline-secondary" %>
  </div>
<% end %>
