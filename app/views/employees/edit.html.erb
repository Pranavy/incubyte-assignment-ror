<% content_for :title, "Edit #{@employee.first_name} #{@employee.last_name} — Employee" %>

<div class="container py-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Employees", employees_path %></li>
      <li class="breadcrumb-item"><%= link_to "#{@employee.first_name} #{@employee.last_name}", employee_path(@employee) %></li>
      <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
  </nav>

  <h1 class="h3 mb-4">Edit employee</h1>
  <p class="text-muted small">You can change name, country, and job title. Salary is set when the employee is created.</p>

  <%= render "form" %>
</div>
